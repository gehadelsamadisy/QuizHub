<!DOCTYPE html>
<html>
<head>
  <title>My Results - QuizHub</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <div class="nav-brand">QuizHub</div>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/quiz/browse">Browse Quizzes</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>

  <div class="container">
    <h1>My Attempts</h1>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <% if (attempts.length === 0) { %>
      <div class="dashboard">
        <p>No attempts yet.</p>
      </div>
    <% } else { %>
      <% attempts.forEach((attempt) => { %>
        <div class="dashboard">
          <h3><%= attempt.quizId ? attempt.quizId.title : 'Quiz' %></h3>
          <p>Status: <%= attempt.gradingStatus %></p>
          <p>Score: <%= attempt.totalScore %> / <%= attempt.maxScore %></p>
          <p>Submitted: <%= attempt.submittedAt ? attempt.submittedAt.toLocaleString() : 'In progress' %></p>
          <a href="/attempt/<%= attempt._id %>" class="btn">View Details</a>
        </div>
      <% }) %>
    <% } %>
  </div>
</body>
</html>