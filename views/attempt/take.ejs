<!DOCTYPE html>
<html>
<head>
  <title>Taking quiz - QuizHub</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <div class="nav-brand">QuizHub</div>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/quiz/browse">Browse</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>

  <div class="container take-quiz">
    <h1><%= quiz.title %></h1>
    <p class="meta">Time limit: <%= quiz.timeLimit %> min · Passing: <%= quiz.passingScore %>%</p>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <div id="timer" class="timer" aria-live="polite"></div>

    <form id="quiz-form" method="POST" action="/attempt/<%= attempt._id %>/submit" enctype="multipart/form-data">
      <% questions.forEach((q, qi) => { %>
        <div class="question-block">
          <p class="q-head"><strong>Question <%= qi + 1 %></strong>
            <span class="pts">(<%= q.points %> pt<%= q.points !== 1 ? 's' : '' %>)</span></p>
          <p class="q-text"><%= q.text %></p>

          <% if (q.type === 'mcq') { %>
            <div class="options">
              <% (q.options || []).forEach((opt, oi) => { %>
                <label class="option-row">
                  <input type="radio" name="mcq[<%= q._id %>]" value="<%= oi %>">
                  <%= opt.text %>
                </label>
              <% }) %>
            </div>
          <% } else if (q.type === 'written') { %>
            <textarea name="written[<%= q._id %>]" rows="5" placeholder="Your answer"></textarea>
          <% } else if (q.type === 'file_upload') { %>
            <label class="file-upload">
              <span>Upload image or PDF</span>
              <input type="file" name="file[<%= q._id %>]" accept="image/*,application/pdf">
            </label>
            <p class="muted">Accepted file types: image or PDF. Maximum size: 10 MB.</p>
          <% } %>
        </div>
      <% }) %>

      <button type="submit" class="btn">Submit quiz</button>
    </form>
  </div>

  <script>
    (function () {
      var endsAt = new Date('<%= endsAt %>').getTime()
      var form = document.getElementById('quiz-form')
      var el = document.getElementById('timer')

      function tick() {
        var now = Date.now()
        var left = Math.max(0, Math.floor((endsAt - now) / 1000))
        var m = Math.floor(left / 60)
        var s = left % 60
        el.textContent = 'Time left: ' + m + ':' + (s < 10 ? '0' : '') + s
        if (left <= 0) {
          if (!form.dataset.autoSubmitted) {
            form.dataset.autoSubmitted = '1'
            el.textContent = 'Time is up — submitting…'
            form.submit()
          }
          return
        }
        setTimeout(tick, 1000)
      }
      tick()
    })()
  </script>

  <style>
    .take-quiz .meta { color: #555; margin-bottom: 0.5rem; }
    .timer {
      font-size: 1.25rem;
      font-weight: bold;
      margin: 1rem 0;
      padding: 0.75rem 1rem;
      background: #fff;
      border-radius: 8px;
      border: 1px solid #ddd;
      display: inline-block;
    }
    .question-block {
      background: #fff;
      padding: 1.25rem;
      margin: 1rem 0;
      border-radius: 8px;
      border: 1px solid #ddd;
    }
    .q-head { margin-bottom: 0.5rem; }
    .pts { color: #666; font-weight: normal; }
    .q-text { margin-bottom: 1rem; }
    .option-row { display: block; margin: 0.5rem 0; cursor: pointer; }
    .file-upload {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      max-width: 28rem;
    }
    .muted { color: #666; font-size: 0.9rem; }
  </style>
</body>
</html>
