<!DOCTYPE html>
<html>
<head>
  <title>QuizHub - Online Quiz & Exam System</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <div class="nav-brand">QuizHub</div>
    <div class="nav-links">
      <% if (user) { %>
        <span>Welcome, <%= user.name %> (<%= user.role %>)</span>
        <a href="/user/profile">Profile</a>
        <% if (user.role === 'teacher') { %>
          <a href="/quiz/create">Create Quiz</a>
          <a href="/quiz/my-quizzes">My Quizzes</a>
        <% } %>
        <% if (user.role === 'student') { %>
          <a href="/quiz/browse">Browse Quizzes</a>
          <a href="/attempt/history">My Results</a>
        <% } %>
        <% if (user.role === 'admin') { %>
          <a href="/admin/users">Admin Panel</a>
        <% } %>
        <a href="/logout">Logout</a>
      <% } else { %>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      <% } %>
    </div>
  </nav>

  <div class="container">
    <h1>Welcome to QuizHub</h1>
    <p>Online Quiz & Exam System</p>

    <% if (!user) { %>
      <div class="cta">
        <a href="/register" class="btn">Get Started</a>
        <a href="/login" class="btn btn-secondary">Login</a>
      </div>
    <% } else { %>
      <div class="dashboard">
        <% if (user.role === 'student') { %>
          <h2>Student Dashboard</h2>
          <p>Take quizzes, view your results, and track your progress.</p>
          <a href="/quiz/browse" class="btn">Browse Available Quizzes</a>
        <% } else if (user.role === 'teacher') { %>
          <h2>Teacher Dashboard</h2>
          <p>Create quizzes, grade submissions, and view analytics.</p>
          <a href="/quiz/create" class="btn">Create New Quiz</a>
        <% } else if (user.role === 'admin') { %>
          <h2>Admin Dashboard</h2>
          <p>Manage users, view all quizzes, and monitor platform statistics.</p>
          <a href="/admin/users" class="btn">Manage Users</a>
        <% } %>
      </div>
    <% } %>
  </div>
</body>
</html>
