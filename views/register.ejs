<!DOCTYPE html>
<html>
<head>
  <title>Register - QuizHub</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <h1>Register</h1>
    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    <form method="POST" action="/register">
      <div>
        <label>Name:</label>
        <input type="text" name="name" required>
      </div>
      <div>
        <label>Email:</label>
        <input type="email" name="email" required>
      </div>
      <div>
        <label>Password:</label>
        <input type="password" name="password" required>
      </div>
      <div>
        <label>Role:</label>
        <select name="role" id="role-select">
          <option value="student" <%= typeof role === 'undefined' || role === 'student' ? 'selected' : '' %>>Student</option>
          <option value="teacher" <%= role === 'teacher' ? 'selected' : '' %>>Teacher</option>
        </select>
      </div>
      <div id="student-fields" style="display: block;">
        <div>
          <label>Major:</label>
          <select name="majorId" id="major-select" required>
            <% majors.forEach((major) => { %>
              <option value="<%= major._id %>" <%= String(major._id) === String(selectedMajorId || '') ? 'selected' : '' %>><%= major.name %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label>Registered Subjects:</label>
          <select name="registeredSubjects" id="registeredSubjects" multiple required></select>
          <small>Hold Ctrl (or Cmd) to select multiple subjects.</small>
        </div>
      </div>
      <button type="submit">Register</button>
    </form>
    <p>Already have an account? <a href="/login">Login</a></p>
  </div>

  <script>
    const majors = <%- JSON.stringify(majors) %>
    const subjects = <%- JSON.stringify(subjects) %>
    const selectedMajorId = '<%= selectedMajorId || '' %>'
    const selectedSubjects = <%- JSON.stringify(selectedSubjects || []) %>
    const role = '<%= typeof role !== 'undefined' ? role : 'student' %>'

    const roleSelect = document.getElementById('role-select')
    const studentFields = document.getElementById('student-fields')
    const majorSelect = document.getElementById('major-select')
    const subjectsSelect = document.getElementById('registeredSubjects')

    function buildSubjectOptions(majorId) {
      const allowedSubjects = subjects.filter((subject) => String(subject.majorId) === String(majorId))
      subjectsSelect.innerHTML = ''
      allowedSubjects.forEach((subject) => {
        const option = document.createElement('option')
        option.value = subject._id
        option.textContent = subject.name
        if (selectedSubjects.map(String).includes(String(subject._id))) {
          option.selected = true
        }
        subjectsSelect.appendChild(option)
      })
    }

    function updateStudentFields() {
      if (roleSelect.value === 'student') {
        studentFields.style.display = 'block'
        majorSelect.required = true
        subjectsSelect.required = true
        buildSubjectOptions(majorSelect.value)
      } else {
        studentFields.style.display = 'none'
        majorSelect.required = false
        subjectsSelect.required = false
        subjectsSelect.innerHTML = ''
      }
    }

    if (selectedMajorId) {
      majorSelect.value = selectedMajorId
    }

    roleSelect.addEventListener('change', updateStudentFields)
    majorSelect.addEventListener('change', () => {
      buildSubjectOptions(majorSelect.value)
    })

    updateStudentFields()
  </script>
</body>
</html>
