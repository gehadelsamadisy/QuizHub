<!DOCTYPE html>
<html>
<head>
  <title>Grade attempt - QuizHub</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <div class="nav-brand">QuizHub</div>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/quiz/<%= quiz._id %>/submissions">Back to submissions</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>

  <div class="container">
    <h1>Grade attempt</h1>
    <p class="meta"><strong><%= quiz.title %></strong><br>
      Student: <%= student ? student.name : '—' %>
      <% if (student && student.email) { %> · <%= student.email %><% } %><br>
      Submitted: <%= attempt.submittedAt ? attempt.submittedAt.toLocaleString() : '—' %>
    </p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <% const manualQs = questions.filter(function (q) { return q.type === 'written' || q.type === 'file_upload' }) %>

    <% if (manualQs.length === 0) { %>
      <p>This quiz has only auto-graded questions. Students already see full results after they submit.</p>
      <p><a href="/quiz/<%= quiz._id %>/submissions" class="btn btn-secondary">Back to submissions</a></p>
    <% } else { %>
      <form method="POST" action="/quiz/<%= quiz._id %>/submissions/<%= attempt._id %>" class="grade-form">
        <% questions.forEach(function (q, qi) {
          const ans = answerMap[q._id.toString()]
          const correctIdx = (q.options || []).findIndex(function (o) { return o.isCorrect })
        %>
          <div class="block">
            <p class="q-title"><strong>Question <%= qi + 1 %></strong> · <%= q.type %> · <%= q.points %> pt max</p>
            <p class="q-text"><%= q.text %></p>

            <% if (q.type === 'mcq' && ans) { %>
              <p class="readonly">Student chose: Option <%= ans.selectedOption != null ? (ans.selectedOption + 1) : '—' %> · Correct: Option <%= correctIdx >= 0 ? (correctIdx + 1) : '—' %> · Points earned: <strong><%= ans.score %></strong></p>
            <% } else if (q.type === 'written' && ans) { %>
              <label>Student answer</label>
              <pre class="answer-box"><%= ans.textAnswer || '(empty)' %></pre>
              <label>Score (0–<%= q.points %>)</label>
              <input type="number" name="scores[<%= q._id %>]" value="<%= ans.score != null ? ans.score : '' %>" min="0" max="<%= q.points %>" step="0.5">
            <% } else if (q.type === 'file_upload') { %>
              <p class="muted">File upload — no file stored in this build.</p>
              <label>Score (0–<%= q.points %>)</label>
              <input type="number" name="scores[<%= q._id %>]" value="<%= ans && ans.score != null ? ans.score : '' %>" min="0" max="<%= q.points %>" step="0.5">
            <% } %>
          </div>
        <% }) %>

        <div class="release-box">
          <label class="chk">
            <input type="checkbox" name="releaseGrades" value="1">
            <strong>Release grades to student</strong> — they can then see scores, pass/fail, and question feedback (required scores above if checked).
          </label>
        </div>

        <button type="submit" class="btn">Save grades</button>
        <a href="/quiz/<%= quiz._id %>/submissions" class="btn btn-secondary">Cancel</a>
      </form>
    <% } %>
  </div>

  <style>
    .meta { color: #555; margin-bottom: 1rem; line-height: 1.5; }
    .block {
      background: #fff;
      border: 1px solid #ddd;
      border-radius: 8px;
      padding: 1rem;
      margin: 1rem 0;
    }
    .q-title { margin-bottom: 0.5rem; }
    .q-text { margin-bottom: 0.75rem; }
    .readonly { color: #333; font-size: 0.95rem; }
    .answer-box {
      white-space: pre-wrap;
      background: #f9f9f9;
      padding: 0.75rem;
      border-radius: 4px;
      border: 1px solid #eee;
      margin: 0.5rem 0 1rem;
    }
    .grade-form input[type="number"] { max-width: 8rem; }
    .release-box {
      background: #eaf4ff;
      border: 1px solid #3498db;
      padding: 1rem;
      border-radius: 8px;
      margin: 1.5rem 0;
    }
    .chk { display: flex; gap: 0.5rem; align-items: flex-start; cursor: pointer; }
    .chk input { margin-top: 0.2rem; }
    .muted { color: #666; font-size: 0.9rem; }
  </style>
</body>
</html>
