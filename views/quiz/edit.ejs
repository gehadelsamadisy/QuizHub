<!DOCTYPE html>
<html>
<head>
  <title>Edit Quiz Settings - QuizHub</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container">
    <h1>Edit quiz settings</h1>
    <p class="meta">Update title, description, subject, time limit, passing score, and attempts per student. Status (draft / published / closed) is unchanged—use My Quizzes or the quiz page for publish, close, or reopen.</p>
    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    <style>.form-actions { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; margin-top: 1rem; }
    .hint { color: #666; font-size: 0.9rem; margin-top: 1rem; }
    .meta { color: #555; margin-bottom: 1rem; }</style>
    <form method="POST" action="/quiz/settings/<%= quiz._id %>">
      <div>
        <label>Title:</label>
        <input type="text" name="title" required value="<%= quiz.title %>">
      </div>
      <div>
        <label>Description:</label>
        <textarea name="description"><%= quiz.description || '' %></textarea>
      </div>
      <div>
        <label>Major:</label>
        <select name="major" required>
          <option value="mechanical-engineering" <%= quiz.major === 'mechanical-engineering' ? 'selected' : '' %>>Mechanical Engineering</option>
          <option value="computer-engineering" <%= quiz.major === 'computer-engineering' ? 'selected' : '' %>>Computer Engineering</option>
          <option value="mechatronics-engineering" <%= quiz.major === 'mechatronics-engineering' ? 'selected' : '' %>>Mechatronics Engineering</option>
        </select>
      </div>
      <div>
        <label>Subject:</label>
        <select name="subject" required>
          <option value="algorithms" <%= quiz.subject === 'algorithms' ? 'selected' : '' %>>Algorithms</option>
          <option value="data-structures" <%= quiz.subject === 'data-structures' ? 'selected' : '' %>>Data Structures</option>
          <option value="databases" <%= quiz.subject === 'databases' ? 'selected' : '' %>>Databases</option>
          <option value="operating-systems" <%= quiz.subject === 'operating-systems' ? 'selected' : '' %>>Operating Systems</option>
          <option value="networks" <%= quiz.subject === 'networks' ? 'selected' : '' %>>Networks</option>
          <option value="machine-learning" <%= quiz.subject === 'machine-learning' ? 'selected' : '' %>>Machine Learning</option>
          <option value="embedded-systems" <%= quiz.subject === 'embedded-systems' ? 'selected' : '' %>>Embedded Systems</option>
          <option value="control-systems" <%= quiz.subject === 'control-systems' ? 'selected' : '' %>>Control Systems</option>
          <option value="thermodynamics" <%= quiz.subject === 'thermodynamics' ? 'selected' : '' %>>Thermodynamics</option>
          <option value="fluid-mechanics" <%= quiz.subject === 'fluid-mechanics' ? 'selected' : '' %>>Fluid Mechanics</option>
          <option value="web-development" <%= quiz.subject === 'web-development' ? 'selected' : '' %>>Web Development</option>
        </select>
      </div>
      <div>
        <label>Time Limit (minutes):</label>
        <input type="number" name="timeLimit" min="1" required value="<%= quiz.timeLimit %>">
      </div>
      <div>
        <label>Passing Score (%):</label>
        <input type="number" name="passingScore" min="0" max="100" required value="<%= quiz.passingScore %>">
      </div>
      <div>
        <label>Attempts allowed per student:</label>
        <input type="number" name="maxAttemptsPerStudent" min="1" max="50" required value="<%= Math.max(1, quiz.maxAttemptsPerStudent || 1) %>">
        <p class="hint">How many times each student may submit this quiz.</p>
      </div>
      <div class="form-actions">
        <button type="submit">Save changes</button>
        <a href="/quiz/<%= quiz._id %>/view" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</body>
</html>
