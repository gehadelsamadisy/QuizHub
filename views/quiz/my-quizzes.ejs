<!DOCTYPE html>
<html>
<head>
  <title>My Quizzes - QuizHub</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container">
    <h1>My Quizzes</h1>
    <a href="/quiz/create" class="btn">Create New Quiz</a>

    <div class="quiz-list">
      <% if (quizzes.length === 0) { %>
        <p>No quizzes created yet.</p>
      <% } else { %>
        <% quizzes.forEach(quiz => { %>
          <div class="quiz-card">
            <h3><%= quiz.title %></h3>
            <p><%= quiz.description %></p>
            <p>Major: <%= quiz.major.replace('-', ' ').replace(/\b\w/g, l => l.toUpperCase()) %> | Subject: <%= quiz.subject.replace('-', ' ').replace(/\b\w/g, l => l.toUpperCase()) %> | Time: <%= quiz.timeLimit %> min | Passing: <%= quiz.passingScore %>% | Attempts per student: <%= Math.max(1, quiz.maxAttemptsPerStudent || 1) %></p>
            <p>Status: <span class="status <%= quiz.status %>"><%= quiz.status %></span></p>
            <div class="quiz-actions">
              <% if (quiz.status === 'draft') { %>
                <a href="/quiz/<%= quiz._id %>/add-questions" class="btn">Add Questions</a>
                <form method="POST" action="/quiz/<%= quiz._id %>/publish" style="display:inline;">
                  <button type="submit">Publish</button>
                </form>
                <form method="POST" action="/quiz/<%= quiz._id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this draft quiz permanently?');">
                  <button type="submit" class="btn-danger">Delete</button>
                </form>
              <% } %>
              <% if (quiz.status === 'published') { %>
                <form method="POST" action="/quiz/<%= quiz._id %>/close" style="display:inline;" onsubmit="return confirm('Stop this quiz for students? They will no longer see it or start it.');">
                  <button type="submit" class="btn-warning">Close</button>
                </form>
              <% } %>
              <% if (quiz.status === 'closed') { %>
                <a href="/quiz/<%= quiz._id %>/add-questions" class="btn">Add Questions</a>
                <form method="POST" action="/quiz/<%= quiz._id %>/reopen" style="display:inline;" onsubmit="return confirm('Make this quiz available to students again? It will appear in Browse and new attempts can start (within attempt limits).');">
                  <button type="submit" class="btn-reopen">Make available again</button>
                </form>
                <form method="POST" action="/quiz/<%= quiz._id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this quiz and all saved attempts permanently?');">
                  <button type="submit" class="btn-delete-all">Delete</button>
                </form>
              <% } %>
              <% if (quiz.status === 'draft' || quiz.status === 'closed') { %>
                <a href="/quiz/settings/<%= quiz._id %>" class="btn btn-secondary">Edit settings</a>
              <% } %>
              <a href="/quiz/<%= quiz._id %>/analytics" class="btn btn-secondary">Analytics</a>
              <a href="/quiz/<%= quiz._id %>/view" class="btn btn-secondary">View</a>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</body>
</html>

<style>
.quiz-card {
  background: white;
  padding: 1rem;
  margin: 1rem 0;
  border-radius: 8px;
  border: 1px solid #ddd;
}

.status {
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
  font-size: 0.9rem;
}

.status.draft { background: #f39c12; color: white; }
.status.published { background: #27ae60; color: white; }
.status.closed { background: #e74c3c; color: white; }

.quiz-actions a, .quiz-actions button {
  margin-right: 0.5rem;
}
.quiz-actions .btn-danger {
  background: #c0392b;
  color: #fff;
  border: none;
  padding: 0.5rem 1rem;
  border-radius: 4px;
  cursor: pointer;
}
.quiz-actions .btn-danger:hover { background: #a93226; }
.quiz-actions .btn-warning {
  background: #e67e22;
  color: #fff;
  border: none;
  padding: 0.5rem 1rem;
  border-radius: 4px;
  cursor: pointer;
}
.quiz-actions .btn-warning:hover { background: #ca6f1d; }
.quiz-actions .btn-delete-all {
  background: #922b21;
  color: #fff;
  border: none;
  padding: 0.5rem 1rem;
  border-radius: 4px;
  cursor: pointer;
}
.quiz-actions .btn-delete-all:hover { background: #7b241c; }
.quiz-actions .btn-reopen {
  background: #1e8449;
  color: #fff;
  border: none;
  padding: 0.5rem 1rem;
  border-radius: 4px;
  cursor: pointer;
}
.quiz-actions .btn-reopen:hover { background: #196f3d; }
</style>
