<!DOCTYPE html>
<html>
<head>
  <title>Browse Quizzes - QuizHub</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container">
    <h1>Available Quizzes</h1>

    <% if (typeof msg !== 'undefined' && msg) { %>
      <div class="notice"><%= msg %></div>
    <% } %>

    <form method="GET" action="/quiz/browse" class="filter-form">
      <label>Filter by Subject:</label>
      <select name="subjectId">
        <option value="">All Subjects</option>
        <% (registeredSubjects || []).forEach(sub => { %>
          <option value="<%= sub._id %>" <%= String(subjectId) === String(sub._id) ? 'selected' : '' %>>
            <%= sub.name %>
          </option>
        <% }) %>
      </select>
      <button type="submit">Filter</button>
      <% if (subjectId) { %>
        <a href="/quiz/browse">Clear Filter</a>
      <% } %>
    </form>

    <div class="quiz-list">
      <% if (quizzes.length === 0) { %>
        <p>No quizzes available.</p>
      <% } else { %>
        <% quizzes.forEach(quiz => { %>
          <div class="quiz-card">
            <h3><%= quiz.title %></h3>
            <p><%= quiz.description %></p>
            <p>Major: <%= quiz.majorId && quiz.majorId.name ? quiz.majorId.name : '—' %> | Subject: <%= quiz.subjectId && quiz.subjectId.name ? quiz.subjectId.name : '—' %> | Time: <%= quiz.timeLimit %> min | Passing: <%= quiz.passingScore %>% · Up to <%= Math.max(1, quiz.maxAttemptsPerStudent || 1) %> attempt(s)</p>
            <a href="/quiz/<%= String(quiz._id) %>/take" class="btn">Start Quiz</a>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <style>
    .quiz-card {
      background: white;
      padding: 1rem;
      margin: 1rem 0;
      border-radius: 8px;
      border: 1px solid #ddd;
    }
    .filter-form {
      background: white;
      padding: 1rem;
      margin: 1rem 0;
      border-radius: 8px;
    }
    .filter-form input {
      width: auto;
      margin-right: 1rem;
    }
    .notice {
      background: #fff3cd;
      border: 1px solid #ffc107;
      padding: 0.75rem 1rem;
      border-radius: 8px;
      margin-bottom: 1rem;
    }
  </style>
</body>
</html>
