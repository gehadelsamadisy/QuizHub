<!DOCTYPE html>
<html>
<head>
  <title>Create Quiz - QuizHub</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container">
    <h1>Create New Quiz</h1>
    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    <style>.form-actions { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; margin-top: 1rem; }
    .hint { color: #666; font-size: 0.9rem; margin-top: 1rem; }</style>
    <form method="POST" action="/quiz/create">
      <div>
        <label>Title:</label>
        <input type="text" name="title" required>
      </div>
      <div>
        <label>Description:</label>
        <textarea name="description"></textarea>
      </div>
      <div>
        <label>Major:</label>
        <select name="major" id="major-select" required>
          <% majors.forEach((major) => { %>
            <option value="<%= major.slug %>" <%= major.slug === selectedMajor ? 'selected' : '' %>><%= major.name %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label>Subject:</label>
        <select name="subject" id="subject-select" required></select>
      </div>
      <div>
        <label>Time Limit (minutes):</label>
        <input type="number" name="timeLimit" min="1" required>
      </div>
      <div>
        <label>Passing Score (%):</label>
        <input type="number" name="passingScore" min="0" max="100" required>
      </div>
      <div>
        <label>Attempts allowed per student:</label>
        <input type="number" name="maxAttemptsPerStudent" min="1" max="50" value="1" required>
        <p class="hint">How many times each student may submit this quiz (default 1).</p>
      </div>
      <div class="form-actions">
        <button type="submit">Create Quiz</button>
        <a href="/quiz/my-quizzes" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
    <p class="hint">Cancel returns to My Quizzes without saving.</p>
  </div>

  <script>
    const majors = <%- JSON.stringify(majors) %>
    const subjects = <%- JSON.stringify(subjects) %>
    const selectedMajor = '<%= selectedMajor %>'
    const selectedSubject = '<%= selectedSubject %>'
    const majorSelect = document.getElementById('major-select')
    const subjectSelect = document.getElementById('subject-select')

    function populateSubjectOptions(majorSlug) {
      const allowedSubjects = subjects.filter((subject) => subject.majorSlug === majorSlug)
      subjectSelect.innerHTML = ''
      allowedSubjects.forEach((subject) => {
        const option = document.createElement('option')
        option.value = subject.slug
        option.textContent = subject.name
        if (subject.slug === selectedSubject) {
          option.selected = true
        }
        subjectSelect.appendChild(option)
      })
    }

    majorSelect.addEventListener('change', () => {
      populateSubjectOptions(majorSelect.value)
    })

    if (selectedMajor) {
      majorSelect.value = selectedMajor
    }
    populateSubjectOptions(majorSelect.value)
  </script>
</body>
</html>
