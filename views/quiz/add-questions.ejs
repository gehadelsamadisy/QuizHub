<!DOCTYPE html>
<html>
<head>
  <title>Add Questions - QuizHub</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <div class="nav-brand">QuizHub</div>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/quiz/my-quizzes">My Quizzes</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>

  <div class="container">
    <h1>Add Questions to: <%= quiz.title %></h1>
    <p>Status: <%= quiz.status %> | Subject: <%= quiz.subject %></p>

    <form method="POST" action="/quiz/<%= quiz._id %>/add-questions" id="quizForm">
      <div id="questions-container">
        <div class="question-block" data-index="0">
          <h3>Question 1</h3>
          <div>
            <label>Question Text:</label>
            <textarea name="questions[0][text]" required></textarea>
          </div>
          <div>
            <label>Question Type:</label>
            <select name="questions[0][type]" class="question-type" onchange="toggleOptions(this, 0)">
              <option value="mcq">Multiple Choice</option>
              <option value="written">Written Answer</option>
              <option value="file_upload">File Upload</option>
            </select>
          </div>
          <div>
            <label>Points:</label>
            <input type="number" name="questions[0][points]" value="1" min="1">
          </div>
          <div class="options-container" id="options-0">
            <label>Options:</label>
            <div class="option">
              <input type="radio" name="questions[0][correctOption]" value="0" required>
              <input type="text" name="questions[0][options][0][text]" placeholder="Option 1">
            </div>
            <div class="option">
              <input type="radio" name="questions[0][correctOption]" value="1">
              <input type="text" name="questions[0][options][1][text]" placeholder="Option 2">
            </div>
            <div class="option">
              <input type="radio" name="questions[0][correctOption]" value="2">
              <input type="text" name="questions[0][options][2][text]" placeholder="Option 3">
            </div>
            <div class="option">
              <input type="radio" name="questions[0][correctOption]" value="3">
              <input type="text" name="questions[0][options][3][text]" placeholder="Option 4">
            </div>
          </div>
          <button type="button" onclick="removeQuestion(0)">Remove Question</button>
          <hr>
        </div>
      </div>

      <button type="button" onclick="addQuestion()">Add Another Question</button>
      <button type="submit">Save Questions</button>
    </form>
  </div>

  <script>
    let questionCount = 1

    function addQuestion() {
      const container = document.getElementById('questions-container')
      const html = `
        <div class="question-block" data-index="${questionCount}">
          <h3>Question ${questionCount + 1}</h3>
          <div>
            <label>Question Text:</label>
            <textarea name="questions[${questionCount}][text]" required></textarea>
          </div>
          <div>
            <label>Question Type:</label>
            <select name="questions[${questionCount}][type]" class="question-type" onchange="toggleOptions(this, ${questionCount})">
              <option value="mcq">Multiple Choice</option>
              <option value="written">Written Answer</option>
              <option value="file_upload">File Upload</option>
            </select>
          </div>
          <div>
            <label>Points:</label>
            <input type="number" name="questions[${questionCount}][points]" value="1" min="1">
          </div>
          <div class="options-container" id="options-${questionCount}">
            <label>Options:</label>
            <div class="option">
              <input type="radio" name="questions[${questionCount}][correctOption]" value="0" required>
              <input type="text" name="questions[${questionCount}][options][0][text]" placeholder="Option 1">
            </div>
            <div class="option">
              <input type="radio" name="questions[${questionCount}][correctOption]" value="1">
              <input type="text" name="questions[${questionCount}][options][1][text]" placeholder="Option 2">
            </div>
            <div class="option">
              <input type="radio" name="questions[${questionCount}][correctOption]" value="2">
              <input type="text" name="questions[${questionCount}][options][2][text]" placeholder="Option 3">
            </div>
            <div class="option">
              <input type="radio" name="questions[${questionCount}][correctOption]" value="3">
              <input type="text" name="questions[${questionCount}][options][3][text]" placeholder="Option 4">
            </div>
          </div>
          <button type="button" onclick="removeQuestion(${questionCount})">Remove Question</button>
          <hr>
        </div>
      `
      container.insertAdjacentHTML('beforeend', html)
      questionCount++
    }

    function removeQuestion(index) {
      const block = document.querySelector(`[data-index="${index}"]`)
      if (block) block.remove()
    }

    function toggleOptions(select, index) {
      const optionsContainer = document.getElementById(`options-${index}`);
      // Select the radio buttons inside this specific question block
      const radioButtons = optionsContainer.querySelectorAll('input[type="radio"]');
      
      if (select.value === 'mcq') {
        optionsContainer.style.display = 'block';
        // Make the first radio button required again
        if (radioButtons.length > 0) {
          radioButtons[0].required = true;
        }
      } else {
        optionsContainer.style.display = 'none';
        // Remove the required attribute so the form can submit
        radioButtons.forEach(radio => radio.required = false);
      }
    }
  </script>

  <style>
    .question-block {
      background: white;
      padding: 1rem;
      margin: 1rem 0;
      border-radius: 8px;
    }
    .option {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin: 0.5rem 0;
    }
  </style>
</body>
</html>
