<!DOCTYPE html>
<html>
<head>
  <title>Analytics - <%= quiz.title %> - QuizHub</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container">
    <h1>Quiz Analytics</h1>
    <p class="meta">Quiz: <strong><%= quiz.title %></strong> · Major: <%= quiz.majorId && quiz.majorId.name ? quiz.majorId.name : '—' %> · Subject: <%= quiz.subjectId && quiz.subjectId.name ? quiz.subjectId.name : '—' %> · Passing Score: <%= quiz.passingScore %>%</p>

    <div class="analytics-summary">
      <div class="summary-card">
        <h3>Average Score</h3>
        <p><strong><%= averageScore.toFixed(1) %></strong> / <%= quizMaxScore %></p>
        <p><%= averagePercent.toFixed(1) %> %</p>
      </div>
      <div class="summary-card">
        <h3>Pass Rate</h3>
        <p><strong><%= passRate.toFixed(1) %> %</strong></p>
        <p><%= passCount %> of <%= gradedCount %> graded attempts</p>
      </div>
      <div class="summary-card">
        <h3>Total Attempts</h3>
        <p><strong><%= totalAttempts %></strong></p>
        <p><%= gradedCount %> graded, <%= totalAttempts - gradedCount %> pending review</p>
      </div>
    </div>

    <% if (totalAttempts === 0) { %>
      <div class="alert alert-info">
        No student attempts have been submitted for this quiz yet.
      </div>
    <% } else { %>
      <div class="chart-panel">
        <canvas id="scoreDistChart"></canvas>
      </div>

      <div class="bucket-list">
        <% for (let i = 0; i < bucketLabels.length; i++) { %>
          <div class="bucket-item">
            <span><%= bucketLabels[i] %></span>
            <strong><%= bucketCounts[i] %></strong>
          </div>
        <% } %>
      </div>
    <% } %>

    <a href="/quiz/my-quizzes" class="btn btn-secondary">Back to My Quizzes</a>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    const ctx = document.getElementById('scoreDistChart')
    if (ctx) {
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: <%- JSON.stringify(bucketLabels) %>,
          datasets: [{
            label: 'Attempt count',
            data: <%- JSON.stringify(bucketCounts) %>,
            backgroundColor: '#3498db',
            borderColor: '#2c3e50',
            borderWidth: 1
          }]
        },
        options: {
          responsive: true,
          scales: {
            y: {
              beginAtZero: true,
              ticks: {
                precision: 0
              }
            }
          }
        }
      })
    }
  </script>
</body>
</html>
