<!DOCTYPE html>
<html>
<head>
  <title>Submissions - <%= quiz.title %> - QuizHub</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container">
    <h1>Student submissions</h1>
    <p class="meta"><%= quiz.title %> · Major: <%= quiz.majorId && quiz.majorId.name ? quiz.majorId.name : '—' %> · Subject: <%= quiz.subjectId && quiz.subjectId.name ? quiz.subjectId.name : '—' %></p>

    <% if (!attempts || attempts.length === 0) { %>
      <p>No submitted attempts yet.</p>
    <% } else { %>
      <div class="release-panel">
        <div>
          <strong>Grades are <%= quiz.gradesReleased ? 'released' : 'not released' %> for this quiz.</strong>
          <p>
            <% if (quiz.gradesReleased) { %>
              Students can see released scores and feedback for completed attempts.
            <% } else { %>
              Students will only see that their submission was received until grades are released.
            <% } %>
            <% if (pendingReviewCount > 0) { %>
              <br><%= pendingReviewCount %> attempt(s) still need manual review before they can be released.
            <% } %>
          </p>
        </div>
        <form method="POST" action="/quiz/<%= quiz._id %>/release-grades" onsubmit="return confirm('Release available grades for this quiz to all students?');">
          <button type="submit" class="btn" <%= releasableCount === 0 && quiz.gradesReleased ? 'disabled' : '' %>>
            Release grades
          </button>
        </form>
      </div>

      <table class="submissions-table">
        <thead>
          <tr>
            <th>Student</th>
            <th>Submitted</th>
            <th>Score</th>
            <th>Grading</th>
            <th>Released</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% attempts.forEach(function (att) {
            const st = att.studentId
            const name = st && st.name ? st.name : 'Student'
            const email = st && st.email ? st.email : ''
          %>
            <tr>
              <td><%= name %><% if (email) { %><br><span class="muted"><%= email %></span><% } %></td>
              <td><%= att.submittedAt ? att.submittedAt.toLocaleString() : '—' %></td>
              <td><%= att.totalScore %> / <%= att.maxScore %></td>
              <td><%= att.gradingStatus %></td>
              <td><%= att.gradesReleased ? 'Yes' : 'No' %></td>
              <td><a href="/quiz/<%= quiz._id %>/submissions/<%= att._id %>" class="btn">Grade / review</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <style>
    .meta { color: #555; margin-bottom: 1rem; }
    .muted { color: #777; font-size: 0.85rem; }
    .release-panel {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: center;
      background: #fff;
      border: 1px solid #ddd;
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 1rem;
    }
    .release-panel p { margin: 0.35rem 0 0; color: #555; }
    .release-panel form { flex-shrink: 0; }
    .release-panel button:disabled {
      opacity: 0.55;
      cursor: not-allowed;
    }
    .submissions-table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid #ddd;
    }
    .submissions-table th,
    .submissions-table td {
      padding: 0.75rem 1rem;
      text-align: left;
      border-bottom: 1px solid #eee;
    }
    .submissions-table th { background: #f8f9fa; }
    .btn { font-size: 0.9rem; padding: 0.35rem 0.75rem; }
  </style>
</body>
</html>
