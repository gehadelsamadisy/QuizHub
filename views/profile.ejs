<!DOCTYPE html>
<html>
<head>
  <title>My Profile - QuizHub</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">

    <h1>My Profile</h1>

    <% if (success) { %>
      <div class="alert alert-success">
        Profile updated successfully!
      </div>
    <% } %>

    <p><strong>Name:</strong> <%= user.name %></p>

    <p><strong>Email:</strong> <%= user.email %></p>

    <p><strong>Role:</strong> <%= user.role %></p>

    <% if (user.role === 'student') { %>
      <p><strong>Major:</strong> <%= user.majorId && user.majorId.name ? user.majorId.name : 'N/A' %></p>

      <p><strong>Registered Subjects:</strong></p>
      <% if (user.registeredSubjects && user.registeredSubjects.length > 0) { %>
        <ul>
          <% user.registeredSubjects.forEach(subject => { %>
            <li><%= subject.name %></li>
          <% }) %>
        </ul>
      <% } else { %>
        <p>No subjects registered.</p>
      <% } %>
    <% } %>

    <a href="/user/profile/edit" class="btn">
      Edit Profile
    </a>

  </div>

</body>
</html>